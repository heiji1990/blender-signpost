---

<footer class="bg-[var(--color-blender-blue)] text-white mt-16">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <p class="text-lg font-bold mb-2">🧭 Blenderの道しるべ</p>
        <p class="text-sm text-blue-200">作りたい表現から探す、Blender学習ナビ</p>
      </div>

      <!-- Links -->
      <div>
        <p class="text-sm font-semibold mb-3 text-blue-200 uppercase tracking-wide">コンテンツ</p>
        <ul class="space-y-2 text-sm">
          <li><a href="/tutorials" class="hover:text-[var(--color-blender-orange)] transition-colors">チュートリアル</a></li>
          <li><a href="/courses" class="hover:text-[var(--color-blender-orange)] transition-colors">有料講座</a></li>
          <li><a href="/addons" class="hover:text-[var(--color-blender-orange)] transition-colors">アドオン</a></li>
          <li><a href="/routes" class="hover:text-[var(--color-blender-orange)] transition-colors">学習ルート</a></li>
        </ul>
      </div>

      <!-- Info -->
      <div>
        <p class="text-sm font-semibold mb-3 text-blue-200 uppercase tracking-wide">サイト情報</p>
        <ul class="space-y-2 text-sm">
          <li><a href="/submit" class="hover:text-[var(--color-blender-orange)] transition-colors">掲載依頼</a></li>
          <li><a href="/contact" class="hover:text-[var(--color-blender-orange)] transition-colors">お問い合わせ</a></li>
          <li><a href="/privacy" class="hover:text-[var(--color-blender-orange)] transition-colors">プライバシーポリシー</a></li>
          <li><a href="/advertising" class="hover:text-[var(--color-blender-orange)] transition-colors">広告・PR表記</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-blue-700 mt-8 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-blue-300">
      <p>© {new Date().getFullYear()} Blenderの道しるべ. All rights reserved.</p>
      <p>当サイトはアフィリエイト広告を含む場合があります。</p>
    </div>
  </div>
</footer>
