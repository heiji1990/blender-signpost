---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import FilterableList from '../../components/filters/FilterableList';

const tutorials = await getCollection('tutorials', ({ data }) => data.status === 'active');
const items = tutorials.map((t) => ({
  id: t.id,
  title: t.data.title,
  url: t.data.url,
  type: t.data.type,
  platform: t.data.platform,
  priceType: t.data.priceType,
  creator: t.data.creator,
  level: t.data.level,
  categories: t.data.categories,
  summary: t.data.summary,
  affiliateUrl: t.data.affiliateUrl ?? undefined,
  isAffiliate: t.data.isAffiliate,
  isPr: t.data.isPr,
  duration: t.data.duration ?? undefined,
  publishedAt: t.data.publishedAt ?? undefined,
  blenderVersion: t.data.blenderVersion ?? undefined,
}));
---

<BaseLayout
  title="チュートリアル一覧"
  description="Blenderの無料チュートリアル動画・記事をレベル・カテゴリ・媒体で絞り込み検索。YouTube・公式ドキュメントなど横断して探せます。"
>
  <div class="max-w-6xl mx-auto px-4 py-10">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-gray-900 mb-2">▶️ チュートリアル一覧</h1>
      <p class="text-gray-600 text-sm">無料チュートリアルをレベル・カテゴリ・媒体から探せます。</p>
    </div>
    <FilterableList items={items} showBlenderVersion={true} showPublishedYear={true} client:load />
  </div>
</BaseLayout>
