---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';
import { levelLabels, platformLabels, platformIcons, categoryLabels } from '../../lib/labels';
import { getYouTubeThumbnail, extractYouTubeId } from '../../lib/youtube';
import { resolveLink } from '../../lib/affiliate';
import { breadcrumb, videoLd } from '../../lib/jsonld';

export async function getStaticPaths() {
  const tutorials = await getCollection('tutorials');
  const active = tutorials.filter((t) => t.data.status === 'active');
  return tutorials.map((t) => {
    const related = active
      .filter((x) => x.id !== t.id && x.data.categories.some((c) => t.data.categories.includes(c)))
      .slice(0, 6)
      .map((x) => ({ id: x.id, title: x.data.title, creator: x.data.creator }));
    return { params: { slug: t.id }, props: { entry: t, related } };
  });
}

const { entry, related } = Astro.props;
const d = entry.data;
const { href, rel } = resolveLink(d);
const ogImage = getYouTubeThumbnail(d.url) ?? undefined;
const ytId = extractYouTubeId(d.url);

const jsonLd: object[] = [
  breadcrumb([
    { name: 'ホーム', path: '/' },
    { name: 'チュートリアル', path: '/tutorials' },
    { name: d.title, path: `/tutorials/${entry.id}` },
  ]),
];
if (ogImage) {
  jsonLd.push(videoLd({
    title: d.title,
    summary: d.summary,
    thumbnail: ogImage,
    embedUrl: ytId ? `https://www.youtube.com/embed/${ytId}` : undefined,
    uploadDate: d.publishedAt,
  }));
}
---

<BaseLayout title={d.title} description={d.summary} ogImage={ogImage} jsonLd={jsonLd}>
  <div class="max-w-3xl mx-auto px-4 py-10">
    <a href="/tutorials" class="text-sm text-gray-500 hover:text-gray-700 mb-6 inline-block">← チュートリアル一覧</a>

    <div class="bg-white rounded-2xl border border-[var(--color-border)] p-6 sm:p-8">
      <!-- Header -->
      <div class="flex flex-wrap gap-2 mb-4">
        <span class="flex items-center gap-1 text-sm text-gray-600">
          {platformIcons[d.platform]}{platformLabels[d.platform] ?? d.platform}
        </span>
        <span class:list={[d.priceType === 'free' ? 'badge-free' : 'badge-paid']}>
          {d.priceType === 'free' ? '無料' : '有料'}
        </span>
        {d.isPr && <span class="badge-pr">PR</span>}
        {d.isAffiliate && !d.isPr && <span class="badge-affiliate">アフィリエイト</span>}
      </div>

      <h1 class="text-xl font-bold text-gray-900 mb-4 leading-snug">{d.title}</h1>

      <p class="text-gray-600 text-sm leading-relaxed mb-6">{d.summary}</p>

      {d.comment && (
        <div class="bg-blue-50 border-l-4 border-[var(--color-blender-blue)] p-4 mb-6 rounded-r-lg">
          <p class="text-sm text-gray-700">{d.comment}</p>
        </div>
      )}

      <!-- Meta grid -->
      <dl class="grid grid-cols-2 sm:grid-cols-3 gap-4 mb-6 text-sm">
        <div>
          <dt class="text-xs text-gray-500 mb-1">制作者</dt>
          <dd class="font-medium">{d.creator}</dd>
        </div>
        {d.duration && (
          <div>
            <dt class="text-xs text-gray-500 mb-1">時間</dt>
            <dd class="font-medium">{d.duration}</dd>
          </div>
        )}
        <div>
          <dt class="text-xs text-gray-500 mb-1">言語</dt>
          <dd class="font-medium">{d.language === 'ja' ? '日本語' : '英語'}</dd>
        </div>
        {d.publishedAt && (
          <div>
            <dt class="text-xs text-gray-500 mb-1">公開日</dt>
            <dd class="font-medium">{d.publishedAt}</dd>
          </div>
        )}
        {d.blenderVersion && (
          <div>
            <dt class="text-xs text-gray-500 mb-1">Blenderバージョン</dt>
            <dd class="font-medium">{d.blenderVersion}</dd>
          </div>
        )}
      </dl>

      <!-- Levels -->
      <div class="mb-4">
        <p class="text-xs text-gray-500 mb-2">対象レベル</p>
        <div class="flex flex-wrap gap-2">
          {d.level.map((l: string) => <span class="badge-level">{levelLabels[l] ?? l}</span>)}
        </div>
      </div>

      <!-- Categories -->
      <div class="mb-6">
        <p class="text-xs text-gray-500 mb-2">カテゴリ</p>
        <div class="flex flex-wrap gap-2">
          {d.categories.map((cat: string) => <span class="tag">{categoryLabels[cat] ?? cat}</span>)}
        </div>
      </div>

      <!-- CTA -->
      <a
        href={href}
        target="_blank"
        rel={rel}
        class="inline-flex items-center gap-2 px-6 py-3 bg-[var(--color-blender-blue)] text-white font-semibold rounded-lg hover:bg-[var(--color-blender-blue-light)] transition-colors"
      >
        {platformIcons[d.platform]} チュートリアルを見る
      </a>

      {(d.isAffiliate || d.isPr) && (
        <p class="text-xs text-gray-400 mt-3">
          ※ {d.isPr ? 'PR掲載です。' : 'アフィリエイトリンクを含みます。'}
          <a href="/advertising" class="underline ml-1">広告・PR表記についてはこちら</a>
        </p>
      )}
    </div>

    {related.length > 0 && (
      <section class="mt-8">
        <h2 class="text-base font-bold text-gray-900 mb-3">関連チュートリアル</h2>
        <ul class="grid sm:grid-cols-2 gap-2">
          {related.map((r) => (
            <li>
              <a href={`/tutorials/${r.id}`} class="block bg-white rounded-lg border border-[var(--color-border)] px-4 py-3 hover:border-[var(--color-blender-blue)] transition-colors">
                <span class="text-sm font-medium text-gray-800 line-clamp-1">{r.title}</span>
                <span class="text-xs text-gray-500 block mt-0.5">{r.creator}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </div>
</BaseLayout>
