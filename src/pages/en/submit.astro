---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Submit Listing (Coming Soon)" noIndex={true}>
  <div class="max-w-2xl mx-auto px-4 py-20 text-center">
    <p class="text-5xl mb-6">🚧</p>
    <h1 class="text-2xl font-bold text-gray-900 mb-4">Submit Listing (Coming Soon)</h1>
    <p class="text-gray-600 mb-2">Listing submissions are not yet open.</p>
    <p class="text-gray-500 text-sm">We will open submissions officially after launch. Please check back later.</p>
    <a href="/en" class="mt-8 inline-block text-sm text-[var(--color-blender-blue)] hover:underline">← Back to Home</a>
  </div>
</BaseLayout>
