---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import FilterableList from '../../../components/filters/FilterableList';

const courses = await getCollection('courses', ({ data }) => data.status === 'active');
const items = courses.map((c) => ({
  id: c.id,
  title: c.data.title,
  url: c.data.url,
  type: c.data.type,
  platform: c.data.platform,
  priceType: c.data.priceType,
  creator: c.data.creator,
  level: c.data.level,
  categories: c.data.categories,
  summary: c.data.summary,
  affiliateUrl: c.data.affiliateUrl,
  isAffiliate: c.data.isAffiliate,
  isPr: c.data.isPr,
  duration: c.data.duration,
}));
---

<BaseLayout
  title="Courses"
  description="Find paid Blender courses on Udemy, Coloso, and more. Filter by level and category."
>
  <div class="max-w-6xl mx-auto px-4 py-10">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-gray-900 mb-2">🎓 Courses</h1>
      <p class="text-gray-600 text-sm">Browse paid Blender courses by level and category.<br class="hidden sm:block" />※ May contain affiliate links.</p>
    </div>
    <FilterableList items={items} lang="en" client:load />
  </div>
</BaseLayout>
