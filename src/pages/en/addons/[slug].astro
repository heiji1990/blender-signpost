---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { platformIcons } from '../../../lib/labels';
import { useTranslations } from '../../../i18n/ui';
import { resolveLink } from '../../../lib/affiliate';
import { breadcrumb, softwareLd } from '../../../lib/jsonld';

export async function getStaticPaths() {
  const addons = await getCollection('addons');
  const active = addons.filter((a) => a.data.status === 'active');
  return addons.map((a) => {
    const related = active
      .filter((x) => x.id !== a.id && x.data.categories.some((c) => a.data.categories.includes(c)))
      .slice(0, 6)
      .map((x) => ({ id: x.id, title: x.data.title, creator: x.data.creator }));
    return { params: { slug: a.id }, props: { entry: a, related } };
  });
}

const t = useTranslations('en');
const { entry, related } = Astro.props;
const d = entry.data;
const { href, rel } = resolveLink(d);

const jsonLd = [
  breadcrumb([
    { name: 'Home', path: '/en/' },
    { name: 'Add-ons', path: '/en/addons' },
    { name: d.title, path: `/en/addons/${entry.id}` },
  ]),
  softwareLd({ title: d.title, summary: d.summary, price: d.price }),
];

const levelLabels: Record<string, string> = {
  beginner_zero: t.level.beginner_zero, beginner: t.level.beginner,
  intermediate: t.level.intermediate, advanced: t.level.advanced,
  career: t.level.career, hobby: t.level.hobby,
};
const categoryLabels: Record<string, string> = {
  beginner: t.category.beginner, geometry_nodes: t.category.geometry_nodes,
  cell_look: t.category.cell_look, loop_animation: t.category.loop_animation,
  character_animation: t.category.character_animation, motion_design: t.category.motion_design,
  logo_animation: t.category.logo_animation, photorealistic: t.category.photorealistic,
  product_cg: t.category.product_cg, addon_usage: t.category.addon_usage,
  freelance: t.category.freelance, sns_portfolio: t.category.sns_portfolio,
  modeling: t.category.modeling, lighting: t.category.lighting,
  rigging: t.category.rigging, compositing: t.category.compositing,
};
const platformLabels: Record<string, string> = {
  youtube: t.platform.youtube, udemy: t.platform.udemy, coloso: t.platform.coloso,
  note: t.platform.note, gumroad: t.platform.gumroad, blender_market: t.platform.blender_market,
  booth: t.platform.booth, official: t.platform.official, x: t.platform.x,
  instagram: t.platform.instagram, web: t.platform.web, addon: t.platform.addon, book: t.platform.book,
};
---

<BaseLayout title={d.title} description={d.summary} ogImage={`/og/addon-${entry.id}.png`} jsonLd={jsonLd}>
  <div class="max-w-3xl mx-auto px-4 py-10">
    <a href="/en/addons" class="text-sm text-gray-500 hover:text-gray-700 mb-6 inline-block">{t.detail.backAddons}</a>

    <div class="bg-white rounded-2xl border border-[var(--color-border)] p-6 sm:p-8">
      <div class="flex flex-wrap gap-2 mb-4">
        <span class="flex items-center gap-1 text-sm text-gray-600">
          {platformIcons[d.platform] ?? '🔧'}{platformLabels[d.platform] ?? d.platform}
        </span>
        <span class:list={[d.priceType === 'free' ? 'badge-free' : d.priceType === 'freemium' ? 'bg-purple-100 text-purple-700 text-xs font-medium px-2 py-0.5 rounded-full' : 'badge-paid']}>
          {d.priceType === 'free' ? t.card.free : d.priceType === 'freemium' ? t.card.freemium : t.card.paid}
        </span>
        {d.price && <span class="text-sm font-semibold text-gray-700">${d.price}</span>}
      </div>

      <h1 class="text-xl font-bold text-gray-900 mb-4">{d.title}</h1>
      <p class="text-gray-600 text-sm leading-relaxed mb-6">{d.summary}</p>

      <dl class="grid grid-cols-2 gap-4 mb-6 text-sm">
        <div><dt class="text-xs text-gray-500 mb-1">{t.detail.developer}</dt><dd class="font-medium">{d.creator}</dd></div>
        {d.blenderVersion && <div><dt class="text-xs text-gray-500 mb-1">{t.detail.supportedVersion}</dt><dd class="font-medium">{d.blenderVersion}</dd></div>}
      </dl>

      <div class="mb-4">
        <p class="text-xs text-gray-500 mb-2">{t.detail.targetLevel}</p>
        <div class="flex flex-wrap gap-2">
          {d.level.map((l: string) => <span class="badge-level">{levelLabels[l] ?? l}</span>)}
        </div>
      </div>
      <div class="mb-6">
        <p class="text-xs text-gray-500 mb-2">{t.detail.categories}</p>
        <div class="flex flex-wrap gap-2">
          {d.categories.map((cat: string) => <span class="tag">{categoryLabels[cat] ?? cat}</span>)}
        </div>
      </div>

      <a
        href={href}
        target="_blank"
        rel={rel}
        class="inline-flex items-center gap-2 px-6 py-3 bg-[var(--color-blender-blue)] text-white font-semibold rounded-lg hover:bg-[var(--color-blender-blue-light)] transition-colors"
      >
        🔧 {t.detail.viewAddon}
      </a>

      <p class="text-xs text-gray-400 mt-4 border-t border-slate-100 pt-4">{t.detail.addonPolicy}</p>
    </div>

    {related.length > 0 && (
      <section class="mt-8">
        <h2 class="text-base font-bold text-gray-900 mb-3">Related add-ons</h2>
        <ul class="grid sm:grid-cols-2 gap-2">
          {related.map((r) => (
            <li>
              <a href={`/en/addons/${r.id}`} class="block bg-white rounded-lg border border-[var(--color-border)] px-4 py-3 hover:border-[var(--color-blender-blue)] transition-colors">
                <span class="text-sm font-medium text-gray-800 line-clamp-1">{r.title}</span>
                <span class="text-xs text-gray-500 block mt-0.5">{r.creator}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </div>
</BaseLayout>
