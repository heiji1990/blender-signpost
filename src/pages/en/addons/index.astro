---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import FilterableList from '../../../components/filters/FilterableList';

const addons = await getCollection('addons', ({ data }) => data.status === 'active');
const items = addons.map((a) => ({
  id: a.id,
  title: a.data.title,
  url: a.data.url,
  type: a.data.type,
  platform: a.data.platform,
  priceType: a.data.priceType,
  creator: a.data.creator,
  level: a.data.level,
  categories: a.data.categories,
  summary: a.data.summary,
  affiliateUrl: a.data.affiliateUrl,
  isAffiliate: a.data.isAffiliate,
  isPr: a.data.isPr,
}));
---

<BaseLayout
  title="Add-ons"
  description="Find Blender add-ons by purpose, price, and level. Browse free and paid add-ons."
>
  <div class="max-w-6xl mx-auto px-4 py-10">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-gray-900 mb-2">🔧 Add-ons</h1>
      <p class="text-gray-600 text-sm">Browse Blender add-ons by category and price.</p>
    </div>
    <FilterableList items={items} lang="en" client:load />
  </div>
</BaseLayout>
