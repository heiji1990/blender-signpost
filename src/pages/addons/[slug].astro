---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { levelLabels, platformLabels, platformIcons, categoryLabels } from '../../lib/labels';
import { resolveLink } from '../../lib/affiliate';
import { breadcrumb, softwareLd } from '../../lib/jsonld';

export async function getStaticPaths() {
  const addons = await getCollection('addons');
  const active = addons.filter((a) => a.data.status === 'active');
  return addons.map((a) => {
    const related = active
      .filter((x) => x.id !== a.id && x.data.categories.some((c) => a.data.categories.includes(c)))
      .slice(0, 6)
      .map((x) => ({ id: x.id, title: x.data.title, creator: x.data.creator }));
    return { params: { slug: a.id }, props: { entry: a, related } };
  });
}

const { entry, related } = Astro.props;
const d = entry.data;
const { href, rel } = resolveLink(d);

const jsonLd = [
  breadcrumb([
    { name: 'ホーム', path: '/' },
    { name: 'アドオン', path: '/addons' },
    { name: d.title, path: `/addons/${entry.id}` },
  ]),
  softwareLd({ title: d.title, summary: d.summary, price: d.price }),
];
---

<BaseLayout title={d.title} description={d.summary} ogImage={`/og/addon-${entry.id}.png`} jsonLd={jsonLd}>
  <div class="max-w-3xl mx-auto px-4 py-10">
    <a href="/addons" class="text-sm text-gray-500 hover:text-gray-700 mb-6 inline-block">← アドオン一覧</a>

    <div class="bg-white rounded-2xl border border-[var(--color-border)] p-6 sm:p-8">
      <div class="flex flex-wrap gap-2 mb-4">
        <span class="flex items-center gap-1 text-sm text-gray-600">
          {platformIcons[d.platform] ?? '🔧'}{platformLabels[d.platform] ?? d.platform}
        </span>
        <span class:list={[d.priceType === 'free' ? 'badge-free' : d.priceType === 'freemium' ? 'bg-purple-100 text-purple-700 text-xs font-medium px-2 py-0.5 rounded-full' : 'badge-paid']}>
          {d.priceType === 'free' ? '無料' : d.priceType === 'freemium' ? '一部無料' : '有料'}
        </span>
        {d.price && <span class="text-sm font-semibold text-gray-700">${d.price}</span>}
      </div>

      <h1 class="text-xl font-bold text-gray-900 mb-4">{d.title}</h1>
      <p class="text-gray-600 text-sm leading-relaxed mb-6">{d.summary}</p>

      <dl class="grid grid-cols-2 gap-4 mb-6 text-sm">
        <div><dt class="text-xs text-gray-500 mb-1">開発者</dt><dd class="font-medium">{d.creator}</dd></div>
        {d.blenderVersion && <div><dt class="text-xs text-gray-500 mb-1">対応バージョン</dt><dd class="font-medium">{d.blenderVersion}</dd></div>}
      </dl>

      <div class="mb-4">
        <p class="text-xs text-gray-500 mb-2">対象レベル</p>
        <div class="flex flex-wrap gap-2">
          {d.level.map((l: string) => <span class="badge-level">{levelLabels[l] ?? l}</span>)}
        </div>
      </div>
      <div class="mb-6">
        <p class="text-xs text-gray-500 mb-2">カテゴリ</p>
        <div class="flex flex-wrap gap-2">
          {d.categories.map((cat: string) => <span class="tag">{categoryLabels[cat] ?? cat}</span>)}
        </div>
      </div>

      <a
        href={href}
        target="_blank"
        rel={rel}
        class="inline-flex items-center gap-2 px-6 py-3 bg-[var(--color-blender-blue)] text-white font-semibold rounded-lg hover:bg-[var(--color-blender-blue-light)] transition-colors"
      >
        🔧 アドオンページを見る
      </a>
    </div>

    {related.length > 0 && (
      <section class="mt-8">
        <h2 class="text-base font-bold text-gray-900 mb-3">関連するアドオン</h2>
        <ul class="grid sm:grid-cols-2 gap-2">
          {related.map((r) => (
            <li>
              <a href={`/addons/${r.id}`} class="block bg-white rounded-lg border border-[var(--color-border)] px-4 py-3 hover:border-[var(--color-blender-blue)] transition-colors">
                <span class="text-sm font-medium text-gray-800 line-clamp-1">{r.title}</span>
                <span class="text-xs text-gray-500 block mt-0.5">{r.creator}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </div>
</BaseLayout>
