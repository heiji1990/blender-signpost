---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="掲載依頼（準備中）" noIndex={true}>
  <div class="max-w-2xl mx-auto px-4 py-20 text-center">
    <p class="text-5xl mb-6">🚧</p>
    <h1 class="text-2xl font-bold text-gray-900 mb-4">掲載依頼（準備中）</h1>
    <p class="text-gray-600 mb-2">現在、掲載依頼の受付を準備中です。</p>
    <p class="text-gray-500 text-sm">サービス開始後に正式にオープンします。しばらくお待ちください。</p>
    <a href="/" class="mt-8 inline-block text-sm text-[var(--color-blender-blue)] hover:underline">← トップへ戻る</a>
  </div>
</BaseLayout>
