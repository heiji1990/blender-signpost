---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import ContentCard from '../components/cards/ContentCard.astro';

const tutorials = await getCollection('tutorials', ({ data }) => data.status === 'active');
const courses = await getCollection('courses', ({ data }) => data.status === 'active');
const addons = await getCollection('addons', ({ data }) => data.status === 'active');
const routes = await getCollection('routes');

const latestTutorials = tutorials.slice(0, 6);
const featuredAddons = addons.slice(0, 4);
const featuredCourses = courses.slice(0, 4);

const popularCategories = [
  { key: 'beginner', label: 'Blender初心者', icon: '🌱', href: '/tutorials?cat=beginner' },
  { key: 'geometry_nodes', label: 'Geometry Nodes', icon: '🔮', href: '/tutorials?cat=geometry_nodes' },
  { key: 'cell_look', label: 'セルルック', icon: '🎨', href: '/tutorials?cat=cell_look' },
  { key: 'loop_animation', label: 'ループアニメ', icon: '🔄', href: '/tutorials?cat=loop_animation' },
  { key: 'motion_design', label: 'モーションデザイン', icon: '✨', href: '/tutorials?cat=motion_design' },
  { key: 'addon_usage', label: 'アドオン活用', icon: '🔧', href: '/addons' },
];

const featuredRoutes = [
  { slug: 'beginner-start', label: '完全初心者向け', icon: '🌱' },
  { slug: 'geometry-nodes', label: 'Geometry Nodes', icon: '🔮' },
  { slug: 'cell-look', label: 'セルルック', icon: '🎨' },
  { slug: 'motion-design', label: 'モーションデザイン', icon: '✨' },
  { slug: 'freelance', label: '案件志向', icon: '💼' },
];
---

<BaseLayout title="Blender道しるべ - 作りたい表現から探すBlender学習ナビ">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-[var(--color-blender-blue)] to-blue-900 text-white py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-3xl sm:text-4xl font-bold mb-3">🧭 Blender道しるべ</h1>
      <p class="text-lg sm:text-xl text-blue-100 mb-8">作りたい表現から探す、Blender学習ナビ</p>
      <p class="text-blue-200 text-sm mb-8">チュートリアル・有料講座・アドオン・学習ルートを目的別に整理</p>

      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/routes"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-[var(--color-blender-orange)] text-white font-semibold rounded-lg hover:bg-[var(--color-blender-orange-light)] transition-colors"
        >
          🗺️ 作りたい表現から探す
        </a>
        <a
          href="/tutorials"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-white/10 text-white font-semibold rounded-lg hover:bg-white/20 transition-colors border border-white/30"
        >
          📚 チュートリアルを探す
        </a>
      </div>
    </div>
  </section>

  <!-- Popular Categories -->
  <section class="py-12 px-4 bg-[var(--color-surface-alt)]">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-xl font-bold mb-6 text-gray-800">🔥 人気カテゴリ</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
        {popularCategories.map((cat) => (
          <a
            href={cat.href}
            class="flex flex-col items-center gap-2 p-4 bg-white rounded-xl border border-[var(--color-border)] hover:border-[var(--color-blender-blue)] hover:shadow-sm transition-all text-center"
          >
            <span class="text-2xl">{cat.icon}</span>
            <span class="text-xs font-medium text-gray-700">{cat.label}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Learning Routes -->
  <section class="py-12 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-gray-800">🗺️ おすすめ学習ルート</h2>
        <a href="/routes" class="text-sm text-[var(--color-blender-blue)] hover:underline">すべて見る →</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {routes.slice(0, 3).map((route) => (
          <a
            href={`/routes/${route.id}`}
            class="flex items-start gap-4 p-4 bg-white rounded-xl border border-[var(--color-border)] hover:shadow-md transition-shadow"
          >
            <div>
              <p class="font-semibold text-sm text-gray-900 mb-1">{route.data.title}</p>
              <p class="text-xs text-gray-500 line-clamp-2">{route.data.description}</p>
              <p class="text-xs text-[var(--color-blender-blue)] mt-2">対象: {route.data.targetLevel}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest Tutorials -->
  <section class="py-12 px-4 bg-[var(--color-surface-alt)]">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-gray-800">▶️ 新着チュートリアル</h2>
        <a href="/tutorials" class="text-sm text-[var(--color-blender-blue)] hover:underline">すべて見る →</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {latestTutorials.map((t) => (
          <ContentCard
            id={t.id}
            title={t.data.title}
            url={t.data.url}
            type={t.data.type}
            platform={t.data.platform}
            priceType={t.data.priceType}
            creator={t.data.creator}
            level={t.data.level}
            categories={t.data.categories}
            summary={t.data.summary}
            affiliateUrl={t.data.affiliateUrl}
            isAffiliate={t.data.isAffiliate}
            isPr={t.data.isPr}
            duration={t.data.duration}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Courses -->
  <section class="py-12 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-gray-800">🎓 注目の有料講座</h2>
        <a href="/courses" class="text-sm text-[var(--color-blender-blue)] hover:underline">すべて見る →</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {featuredCourses.map((c) => (
          <ContentCard
            id={c.id}
            title={c.data.title}
            url={c.data.url}
            type={c.data.type}
            platform={c.data.platform}
            priceType={c.data.priceType}
            creator={c.data.creator}
            level={c.data.level}
            categories={c.data.categories}
            summary={c.data.summary}
            affiliateUrl={c.data.affiliateUrl}
            isAffiliate={c.data.isAffiliate}
            isPr={c.data.isPr}
            duration={c.data.duration}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Addons -->
  <section class="py-12 px-4 bg-[var(--color-surface-alt)]">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-gray-800">🔧 注目アドオン</h2>
        <a href="/addons" class="text-sm text-[var(--color-blender-blue)] hover:underline">すべて見る →</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {featuredAddons.map((a) => (
          <ContentCard
            id={a.id}
            title={a.data.title}
            url={a.data.url}
            type={a.data.type}
            platform={a.data.platform}
            priceType={a.data.priceType}
            creator={a.data.creator}
            level={a.data.level}
            categories={a.data.categories}
            summary={a.data.summary}
            affiliateUrl={a.data.affiliateUrl}
            isAffiliate={a.data.isAffiliate}
            isPr={a.data.isPr}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Submit CTA -->
  <section class="py-12 px-4 bg-[var(--color-blender-blue)] text-white">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-xl font-bold mb-3">掲載依頼・お問い合わせ</h2>
      <p class="text-blue-200 text-sm mb-6">チュートリアル・講座・アドオンの掲載依頼や、修正依頼はこちらから</p>
      <div class="flex gap-3 justify-center">
        <a
          href="/submit"
          class="px-5 py-2.5 bg-[var(--color-blender-orange)] text-white font-semibold rounded-lg hover:bg-[var(--color-blender-orange-light)] transition-colors"
        >
          掲載依頼
        </a>
        <a
          href="/contact"
          class="px-5 py-2.5 bg-white/10 text-white font-semibold rounded-lg hover:bg-white/20 transition-colors border border-white/30"
        >
          お問い合わせ
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
